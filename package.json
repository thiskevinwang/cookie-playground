{
  "name": "cookie-playground",
  "private": true,
  "devDependencies": {
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "bun --watch run --filter '*' --elide-lines=0 dev",
    "certs:setup": "node scripts/certs.js setup",
    "certs:cleanup": "node scripts/certs.js cleanup",
    "proxy": "node scripts/proxy.js"
  },
  "dependencies": {
    "hono": "^4.8.5",
    "http-proxy": "^1.18.1"
  }
}
